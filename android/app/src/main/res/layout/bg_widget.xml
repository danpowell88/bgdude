<?xml version="1.0" encoding="utf-8"?>
<!-- Home-screen BG widget layout (RemoteViews-safe views only).

     Left: big glucose value + trend arrow (coloured by range, greyed when stale).
     Right: unit label, IOB line, and updated-ago text. Sized to read comfortably
     in a 2x1 cell; scales up gracefully when resized. Static dark card so it is
     legible on any wallpaper in both light and dark system themes. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_widget_background"
    android:orientation="horizontal"
    android:gravity="center"
    android:paddingHorizontal="16dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/bg_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text="--"
        android:textColor="#FF9E9E9E"
        android:textSize="34sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/bg_trend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:text=""
        android:textColor="#FF9E9E9E"
        android:textSize="22sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:gravity="center_vertical"
        android:orientation="vertical">

        <TextView
            android:id="@+id/bg_unit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:text=""
            android:textColor="#99FFFFFF"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/iob_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:text="IOB --"
            android:textColor="#CCFFFFFF"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/updated_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:text="no data"
            android:textColor="#99FFFFFF"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>

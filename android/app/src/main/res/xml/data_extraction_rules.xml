<?xml version="1.0" encoding="utf-8"?>
<!--
  Issue #327: exclude ALL app data from both cloud backup and device-to-device
  transfer (API 31+). Paired with android:allowBackup="false" for ≤API 30.
  A diabetes app's local encrypted health database is deliberately not backed up.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
        <exclude domain="external" />
    </device-transfer>
</data-extraction-rules>

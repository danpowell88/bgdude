# Copy to .env (which is gitignored) and fill in.
#
# GH_RUNNER_PAT: a FINE-GRAINED personal access token scoped to danpowell88/bgdude with
#   Repository permissions -> Administration: Read and write (that's what lets the container
#   self-register/deregister a runner). Create at:
#   https://github.com/settings/personal-access-tokens/new
#   Treat it like a password; it lives only in this .env on your Unraid box.
GH_RUNNER_PAT=github_pat_replace_me
